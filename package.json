{
  "name": "familien-code-v2",
  "version": "2.0.0",
  "private": true,
  "description": "Familien-Code v2: Numerologie & Astrologie Profi-Tool fuer herzbewegung.ch",
  "author": "Mauro Casellini",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "electron:dev": "concurrently -k -n NEXT,ELECTRON -c yellow,blue \"npm:dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron-builder",
    "electron:build:mac": "next build && electron-builder --mac",
    "electron:build:win": "next build && electron-builder --win",
    "electron:build:all": "next build && electron-builder --mac --win"
  },
  "build": {
    "appId": "ch.herzbewegung.familien-code",
    "productName": "FamilienCode",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "public/**/*",
      "pages/**/*",
      "styles/**/*",
      "next.config.js",
      "package.json",
      "node_modules/**/*",
      "!node_modules/{electron,electron-builder,sharp,concurrently,wait-on,@electron-toolkit}/**/*",
      "!node_modules/swisseph/**/*",
      "!**/.next/cache/**/*",
      "!**/*.{md,test.js,spec.js}",
      "!.env.local",
      "!.env*.local"
    ],
    "extraResources": [
      {
        "from": "icon.png",
        "to": "icon.png"
      }
    ],
    "asar": false,
    "mac": {
      "category": "public.app-category.lifestyle",
      "icon": "icon.png",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "darkModeSupport": false,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Familien-Code v${version}",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "win": {
      "icon": "icon.png",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "linux": {
      "icon": "icon.png",
      "target": "AppImage",
      "category": "Office"
    }
  },
  "dependencies": {
    "@upstash/redis": "^1.34.0",
    "docx": "^9.6.1",
    "next": "14.2.3",
    "react": "^18",
    "react-dom": "^18"
  },
  "optionalDependencies": {
    "swisseph": "^0.5.17"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "wait-on": "^9.0.10"
  }
}
